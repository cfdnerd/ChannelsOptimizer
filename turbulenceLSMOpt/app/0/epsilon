FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      epsilon;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -3 0 0 0 0];

// Symmetric half-domain: modeled inlet width = 4 mm, full physical inlet = 8 mm.
// Using the full physical inlet diameter in the turbulence length scale:
// ell = 0.07*Dh = 0.07*8e-3 m, epsilon = Cmu^0.75*k^1.5/ell = 6.73815e-2 m2/s3.
internalField   uniform 6.73815e-2;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 6.73815e-2;
    }

    outlet
    {
        type            inletOutlet;
        inletValue      uniform 6.73815e-2;
        value           uniform 6.73815e-2;
    }

    Wall
    {
        type            fixedValue;
        value           uniform 1e-4;
    }

    right
    {
        type            symmetry;
    }

    frontAndBack
    {
        type            empty;
    }
}

