FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      optProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

voluse              0.4;
filterR             10;
PowerDiss0          8e-4;
PowerDissMax        10;
PowerDissRelax      15;
powerConstraintRelaxationRate 0.02;
continuationFeasibilityTol 1.15;
GeoDim              2;
fluid_area          yes;
solid_area          no;
test_area           no;
Pnorm               300;
objFunction         1;
qAlpha0             0.005;
qAlphaMin           1e-3;
qKappa0             0.005;
qKappaMin           1e-3;
qHeat0              0.005;
qHeatMin            1e-3;
qSingle0            0.005;
qSingleMin          0.005;
qContinuationStartIter 1000;
qContinuationInterval 10;
qContinuationFactor 0.9;

beta0               0.5;
betaMax             100;
betaIncrement       0.12;
alphaRampEarlySlope 0.08;
alphaRampLateFactor 1.0;

dAlphaPorosityEps   1e-3;
epsilonLSM          1.5;
epsilonLSMMin       0.5;
lsmVelocityRadius   10;
lsmCFL              0.2;
maxNormalVelocity   0.25;
maxVolumePhiShiftFactor 0.10;
maxTurbulentViscosity 1e-3;
reinitInterval      5;
reinitPseudoSteps   5;
reinitTolerance     0.10;

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
