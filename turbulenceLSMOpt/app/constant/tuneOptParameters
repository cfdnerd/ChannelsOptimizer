FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      tuneOptParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

frameworkSwitches
{
    useFrozenTurbulenceAdjoint      true;                  // Use the implemented frozen-turbulence adjoint path.
    useKEpsilonModel                true;                  // Use the baseline k-epsilon turbulence model.
    useWrayAgarwalFallback          false;                 // Unimplemented fallback model; keep off.
    usePorosityWallDistance         true;                  // Use porosity-aware wall distance for blocked regions.
    useMeshWaveWallDistanceFallback false;                 // Mesh-wave fallback wall distance; only use if needed.
    useBrinkmanSinkInKEpsilon       true;                  // Include porous Brinkman damping in turbulence equations.
    useSplitRAMPControls            false;                 // Use separate qAlpha/qKappa/qHeat continuation controls.
    useSingleQFallback              true;                  // Use one shared q continuation parameter instead.
    useTurbulentThermalDiffusivity  true;                  // Include turbulent thermal diffusivity in heat transport.
    usePowerConstraintRelaxation    true;                  // Relax the power constraint early, then tighten it.
    useGCMMA                        false;                 // GCMMA path is not implemented here.
    useFullAdjointSymmetricStress   true;                  // Use the stronger adjoint stress term when probing sensitivity fidelity.
}

objectiveSwitches
{
    useLogMeanTObjective            false;                 // Optimize log(mean T) instead of mean T.
    useKSHotspotObjective           false;                 // Optimize a hotspot-focused KS temperature measure.
    useVarianceObjective            false;                 // Optimize temperature uniformity instead of average level.
    useRobustMultiCaseObjective     false;                 // Multi-case robust objective; not implemented for this branch.
}

continuationSwitches
{
    useStagnationTriggeredBeta      false;                 // Only harden beta after stagnation instead of every allowed step.
    useLateStageFilterRCap          false;                 // Allow the late-stage filter-radius cap to override filterR after its trigger.
}

experimentControl
{
    profile                         branchRefinement400;   // Active continuation preset to apply at runtime.
    forceContinuationHardening      false;                 // Ignore the feasibility gate and always harden continuation.
    forceContinuationHardeningUntilIter 0;                 // Keep hardening forced until this iteration.
    forceContinuationHardeningUntilBeta -1;                // Keep hardening forced until beta reaches this value.
    stopContinuationHardeningBelowGrayFraction 0.10;       // Fully stop hardening once gray is already low enough.
    lateStageStrictGateBelowGrayFraction 0.14;             // Switch to a stricter power-feasibility gate below this gray level.
    lateStageContinuationFeasibilityTol 0.98;              // Stricter late-stage PowerDiss/limit tolerance.
    lateStageRefinementStartIter   170;                    // Start late refinement taper from this iteration onward.
    lateStageRefinementBelowGrayFraction 0.18;             // Also start refinement taper once gray drops below this level.
    lateStageBetaRampFactor        0.25;                   // Scale betaIncrement during late refinement.
    lateStageAlphaRampFactor       1.0;                    // Replace late alpha growth factor during refinement.
    lateStageMaxBeta               40;                     // Cap beta during late refinement to preserve carveable gray.
    lateStageFilterRStartIter      120;                    // Keep the dictionary filterR through this iteration, then switch to the cap.
    lateStageFilterRCap            6.0;                    // Late-stage filter-radius cap used after lateStageFilterRStartIter.
    laggingGrayCollapseStartIter   140;                    // Start checking for stalled gray collapse from this iteration.
    laggingGrayCollapseAboveGrayFraction 0.30;             // Only treat the run as stalled while gray is still this high.
    laggingGrayCollapseBelowXhStepMax 0.06;                // Stagnation test: topology motion is too small below this xhStepMax.
    laggingGrayCollapseMinGrayDrop 5e-3;                   // Stagnation test: gray is barely decreasing below this per-step drop.
    laggingGrayCollapsePauseInterval 4;                    // Even when throttled, allow one hardening pulse every N steps.
    overactiveTopologyStartIter    180;                    // Start checking for overactive late topology from this iteration.
    overactiveTopologyBelowGrayFraction 0.16;              // Only apply the overactive throttle once gray is already low.
    overactiveTopologyAboveXhStepMax 0.20;                 // Pause hardening when recent xh motion is already too violent.
}

adjointControl
{
    adjointMomentumSweeps           30;                    // Slightly higher adjoint fidelity for stronger late-stage branch sensitivities.
    adjointExplicitStressScale      0.30;                  // Conservative increase to strengthen the symmetric-stress contribution without reverting to runaway.
    resetAdjointsEachIteration      true;                  // Reinitialize adjoints each loop for robustness.
    stopOnAdjointRunaway            true;                  // Abort optimization if adjoint magnitudes blow up.
}

hybridStageControl
{
    useHybridMMAtoLSM               true;                  // Enable the staged density-to-level-set workflow.
    lsmSwitchGrayFraction           0.20;                  // Only switch once the density design is mostly crisp.
    lsmSwitchPowerFeasibility       1.05;                  // Require near-feasible power dissipation before handover.
    lsmSwitchMaxXhStep              0.08;                  // Require the density stage to behave like refinement, not exploration.
    lsmSwitchMinBeta                12;                    // Minimum projection sharpness before Stage 2 can begin.
    lsmSwitchMinIterations          120;                   // Minimum density-stage maturity window before considering the switch.
    lsmSwitchRequireConnectivity    true;                  // Require a connected inlet-to-outlet fluid path before switching.
    lsmBlendIterations              5;                     // Blend density and level-set reconstructions over this many iterations.
    lsmRollbackEnabled              true;                  // Allow the run to revert to the Stage-1 checkpoint if Stage 2 goes unstable.
    requireRestartableLSMCheckpoint true;                  // Refuse the handover unless rollback support is available.
    allowTopologyChangeInLSM        false;                 // Preserve topology by default during the refinement stage.
}

lsmControl
{
    useLevelSetStage                true;                  // Enable the Stage-2 level-set refinement machinery.
    phiBandWidthCells               1.5;                   // Smooth-Heaviside half-width, in cell-length units.
    narrowBandHalfWidthCells        4.0;                   // Restrict Hamilton-Jacobi updates to this signed-distance band.
    phiReinitInterval               5;                     // Reinitialize the signed-distance field every N LSM iterations.
    phiGradDriftTol                 0.25;                  // Also reinitialize when |grad(phi)| drifts too far from one.
    lsmPseudoDt                     0.0;                   // Zero uses CFL-only pseudo-time stepping.
    lsmCfl                          0.50;                  // Cap the pseudo-time step using a CFL-style limit.
    useVelocityHelmholtz            true;                  // Smooth the total normal velocity before updating phi.
    velocityFilterRadius            2.0;                   // Velocity-regularization radius, in cell-length units.
    useCurvaturePenalty             true;                  // Add curvature suppression to the interface motion.
    curvaturePenaltyWeight          0.05;                  // Weight for the curvature-smoothing velocity term.
    useReactionDiffusionComplexityControl false;           // Optional extra smoothing path; off in the baseline.
}

lsmSensitivityControl
{
    useApproximateNarrowBandSensitivityBridge true;        // Reuse xh sensitivities through a narrow-band interface bridge.
    lsmSensitivitySmoothingRadius   2.0;                   // Smoothing radius for geometry-control extension fields.
    normalizeInterfaceVelocity      true;                  // Normalize interface-velocity components before combining them.
    finiteDifferenceCheckStage2     false;                 // When enabled, keep extra LSM fields for manual FD validation.
}

geometryControl
{
    useChannelWidthControl          true;                  // Enable minimum/maximum channel-width refinement.
    channelWidthMin                 4.0;                   // Global minimum channel width target in mesh-length units.
    channelWidthMax                 14.0;                  // Global maximum channel width target in mesh-length units.
    useRegionwiseWidthTargets       false;                 // Promote width targets from global to regionwise when needed.
    useBranchwiseWidthTargets       false;                 // Later milestone; keep disabled in the first implementation.
    useRibThicknessControl          true;                  // Enforce a minimum rib-thickness target.
    ribThicknessMin                 3.0;                   // Global minimum rib thickness target in mesh-length units.
    useRibThicknessMaxControl       false;                 // Optional maximum rib-thickness trimming.
    ribThicknessMax                 12.0;                  // Maximum rib thickness target where that control is enabled.
    useRegionwiseRibTargets         false;                 // Promote rib targets from global to regionwise when needed.
    useBranchwiseRibTargets         false;                 // Later milestone; keep disabled in the baseline branch.
    useProtectedGeometryMasks       false;                 // Apply protected masks only when explicitly configured.
    applyRibTargetsToInternalRibsOnly true;                // Do not erode boundary-attached walls with rib-max control.
    useHydraulicDiameterReporting   false;                 // Report hydraulic diameter only when an extrusion thickness is supplied.
    hydraulicDiameterExtrusionThickness 1.0;               // Extrusion thickness used in the hydraulic-diameter report.
    ksRhoGeom                       20.0;                  // KS sharpness for aggregated geometry violations.
    sizeConstraintWeightMin         1.0;                   // Weight for minimum-size corrections.
    sizeConstraintWeightMax         1.0;                   // Weight for maximum-size corrections.
    widthConstraintWeight           1.0;                   // Overall weight for channel-width correction velocities.
    ribConstraintWeight             1.0;                   // Overall weight for rib-thickness correction velocities.
    protectedSolidRegionNames       ();
    protectedFluidRegionNames       ();
    regionwiseChannelWidthMin       {}
    regionwiseChannelWidthMax       {}
    regionwiseRibThicknessMin       {}
    regionwiseRibThicknessMax       {}
}

wallDistanceControl
{
    lsmWallDistanceMode             porosity;              // Keep porosity-aware wall distance as the safe baseline.
    useLSMWallDistance              false;                 // Enable only after Stage-2 validation if desired.
    useHeatMethodWallDistanceFallback false;               // Reserved for later wall-distance experiments.
    lsmWallDistanceBlendIterations  5;                     // Blend porosity and phi-based wall distance over early Stage 2.
}

convergenceControl
{
    optPowerConstraintWeight        2.0;                   // Relative penalty weight on power-constraint violation.
    optPowerViolationScaleExponent  1.0;                   // Nonlinear scaling exponent for power-violation weighting.
}

