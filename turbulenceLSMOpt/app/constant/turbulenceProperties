FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      turbulenceProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //
simulationType RAS;
// The case is modeled as a symmetric half-domain.
// The inlet patch width is 4 mm in the mesh, corresponding to an 8 mm physical inlet.

RAS
{
    RASModel        kEpsilon;

    turbulence      on;

    printCoeffs     on;
}


