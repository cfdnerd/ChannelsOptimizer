FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    "(p|pc)"
    {
        solver          GAMG;
        tolerance       1e-10;
        relTol          0;
        smoother        GaussSeidel;
        cacheAgglomeration true;
        agglomerator    faceAreaPair;
        mergeLevels     1;
        nPreSweeps      0;
        nPostSweeps     2;
        nFinestSweeps   2;
        maxIter         5000;
    }
    "pb"
    {
        solver          GAMG;
        tolerance       1e-10;
        relTol          0;
        smoother        GaussSeidel;
        cacheAgglomeration true;
        agglomerator    faceAreaPair;
        mergeLevels     1;
        nPreSweeps      0;
        nPostSweeps     4;
        nFinestSweeps   4;
        maxIter         5000;
    }
    "pa"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-10;
        relTol          0;
        maxIter         10000;
    }

    "(U|Uc|k|epsilon)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         2;
        tolerance       1e-9;
        relTol          0;
        maxIter         5000;
    }
    "(Ua|Ub)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        nSweeps         1;
        tolerance       1e-10;
        relTol          0;
        maxIter         5000;
    }
     "T"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-10;
        relTol          0;
        maxIter         10000;
    }  
     "Ta"
    {
        solver          GAMG;
        tolerance       1e-10;
        relTol          0;
        smoother        GaussSeidel;
        cacheAgglomeration true;
        agglomerator    faceAreaPair;
        mergeLevels     1;
        nPreSweeps      0;
        nPostSweeps     2;
        nFinestSweeps   2;
        nCellsInCoarsestLevel 20;
        maxIter         20000;
    }
     "Tb"
    {
        solver          GAMG;
        tolerance       1e-10;
        relTol          0;
        smoother        symGaussSeidel;
        cacheAgglomeration false;
        agglomerator    faceAreaPair;
        mergeLevels     1;
        nPreSweeps      1;
        nPostSweeps     4;
        nFinestSweeps   4;
        nCellsInCoarsestLevel 200;
        maxIter         20000;
    }
     "(xp|dAlpha2|fsensMeanT|gsensVol|gsensPowerDiss|lsmWidthVelocity|lsmRibVelocity|lsmNormalVelocity|phiReactionDiffused)"
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-8;
        relTol          0;
        maxIter         5000;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 2;
    consistent no;
 //   nCorrectors 2;
// nOuterCorrectors 10;
    pRefCell 0;
    pRefValue 0;

}

relaxationFactors
{
    fields
    {
        "(p|pc)"        0.3;
        pb              0.2;
        pa              0.1;
        alpha           0.1;
    }
    equations
    {
        "(U|Uc)"        0.7;
        "(Ua|Ub)"       0.3;
        "(k|epsilon)"   0.7;
    }
}
constraintFunctionDict_flow
{
    numberConstraintPatches      2;
    constraintPatchesNames       (inlet outlet);
}
constraintFunctionDict_solid
{
    numberConstraintPatches      1;
    constraintPatchesNames       (force);
}
