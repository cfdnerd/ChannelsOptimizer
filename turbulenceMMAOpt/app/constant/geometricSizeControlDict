FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      geometricSizeControlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

general
{
    aggregationKSFactor      40;      // KS sharpness used to aggregate local solid-size violations.
    smoothPositiveEps        1e-4;    // Smooth positive-part epsilon used in the local violation functions.
    writeDiagnosticFields    false;   // Write solid-indicator/filter/violation fields for debugging.
    projectionBeta           4.0;     // Mild projection used only by the geometry-control channel xg.
    projectionEta            -1;      // Geometry-channel threshold. Negative reuses the current physics eta5.
    activationMinIter        120;     // Wait until the late branch-birth window before enforcing solid-size breakup.
    activationGrayEnter      0.45;    // Activate once the main trunks are formed but late gray side-branch seeds remain.
    activationGrayExit       0.50;    // Keep the gate latched through moderate gray rebounds during late branch carving.
    activationXhStepMax      -1;      // Disable the xh-step gate; the branch-refinement regime stays too mobile for a low step cutoff.
    activationHoldIters      3;       // Activate quickly once the late-stage gray gate is satisfied.
    rampIters                12;      // Bring the geometric constraint on faster while side-branch seeds are still present.
    freezeHardeningWhileInfeasible true; // Freeze further alpha/beta hardening while an active geometry constraint is violated.
    constraintScaleTarget    0.05;    // MMA normalization floor used for geometric constraints after stage activation.
}

minSolidGeometryControl
{
    active                   false;   // Solid-only minimum-size control. Penalizes thin unsupported solid ligaments.
    featureSize              3.0;     // Feature-size radius in the same effective units as optProperties.filterR.
    fillFraction             0.55;    // Require at least this local solid occupancy around nominal solid cells.
    tolerance                1e-4;    // Allow this much aggregated violation before the MMA constraint activates.
    constraintWeight         1.0;     // Relative weight applied to the MMA min-solid constraint.
}

maxSolidGeometryControl
{
    active                   true;    // Turn on explicit breakup of oversized solid trunks/ribs during late branch refinement.
    featureSize              5.0;     // Match the late-stage active filter scale so bulky solids are split where new sub-branches should nucleate.
    fillFraction             0.72;    // Penalize dense local solid neighborhoods early enough to stop thick trunks from monopolizing the domain.
    tolerance                5e-4;    // Allow a small violation band before the MMA max-solid constraint starts pushing back.
    constraintWeight         0.8;     // Moderate weight so breakup guidance helps branch bifurcation without overwhelming thermal/power sensitivities.
}

