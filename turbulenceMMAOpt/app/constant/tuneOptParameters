FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      tuneOptParameters;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

frameworkSwitches
{
    useFrozenTurbulenceAdjoint      true;
    useKEpsilonModel                true;
    useWrayAgarwalFallback          false;
    usePorosityWallDistance         true;
    useMeshWaveWallDistanceFallback false;
    useBrinkmanSinkInKEpsilon       true;
    useSplitRAMPControls            false;
    useSingleQFallback              true;
    useTurbulentThermalDiffusivity  true;
    usePowerConstraintRelaxation    true;
    useGCMMA                        false;
    useFullAdjointSymmetricStress   false;
}

objectiveSwitches
{
    useLogMeanTObjective            false;
    useKSHotspotObjective           false;
    useVarianceObjective            false;
    useRobustMultiCaseObjective     false;
}

continuationSwitches
{
    useStagnationTriggeredBeta      false;
}

// Gray-fraction debugging presets.
// baseline: keep case values unchanged
// laminarGrayRamp: use laminar-style beta/alpha continuation
// relaxedGateGrayRamp: laminar-style continuation with a looser feasibility gate
// ungatedGrayRamp: laminarGrayRamp + bypass the continuation feasibility gate
// adjointSensitivityProbe: increase adjoint fidelity to test whether weak
// objective/power sensitivities are suppressing topology changes
experimentControl
{
    profile                         relaxedGateGrayRamp;
    forceContinuationHardening      false;
}

adjointControl
{
    adjointMomentumSweeps           20;
    resetAdjointsEachIteration      true;
    stopOnAdjointRunaway            true;
}

// Optimizer stopping controls.
// The optimizer exits early only after the design step, objective drift,
// and constraint violation all remain small for several consecutive loops.
convergenceControl
{
    optPowerConstraintWeight        2.0;
    optPowerViolationScaleExponent  1.0;
}

